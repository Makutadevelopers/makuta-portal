# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (AWS RDS PostgreSQL) ─────────────────────────
DB_HOST=your-rds-endpoint.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=makuta_portal
DB_USER=makuta_admin
DB_PASSWORD=your_secure_password_here
DB_SSL=true

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string_generated_by_openssl
JWT_EXPIRES_IN=8h

# ── AWS S3 (invoice attachments) ─────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=makuta-invoice-attachments

# ── Client (Vite) ─────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api
