# ── Server ────────────────────────────────────────────────
# NODE_ENV=production triggers strict config validation — placeholders below will be rejected
NODE_ENV=development
PORT=4000

# ── Database ─────────────────────────────────────────────
# For local Docker: use localhost and DB_PORT from docker-compose
# For AWS RDS:  use your-rds-endpoint.ap-south-1.rds.amazonaws.com and DB_SSL=true
DB_HOST=localhost
DB_PORT=5433
DB_NAME=makuta_portal
DB_USER=makuta_admin
DB_PASSWORD=localdevpassword
DB_SSL=false

# ── JWT ───────────────────────────────────────────────────
# Generate a strong secret:  openssl rand -hex 48
# Production startup is blocked if this is still the placeholder or shorter than 48 chars.
JWT_SECRET=replace_with_64_char_random_string_generated_by_openssl
JWT_EXPIRES_IN=8h

# ── AWS S3 (invoice attachments) ─────────────────────────
# Leave as placeholders for local dev (files save to server/uploads/)
# For production, set real keys so attachments go to S3.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=local_dev_key
AWS_SECRET_ACCESS_KEY=local_dev_secret
S3_BUCKET_NAME=makuta-invoice-attachments

# ── Email (optional) ─────────────────────────────────────
# Leave empty to disable email notifications
# Set SMTP credentials to enable (e.g., AWS SES, Gmail, SendGrid)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@makutadevelopers.com

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Production: set to your real frontend domain(s), e.g.  https://portal.makutadevelopers.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Cron shared secret ────────────────────────────────────
# Required in production so /api/cron/* endpoints can authenticate.
# Generate: openssl rand -hex 32
CRON_SECRET=

# ── Backups ──────────────────────────────────────────────
# S3 bucket for database backups (defaults to S3_BUCKET_NAME)
# S3_BACKUP_BUCKET=makuta-backups
# BACKUP_DIR=./backups
# RETENTION_DAYS=30

# ── Client (Vite) ────────────────────────────────────────
VITE_API_BASE_URL=/api
# Set to "true" to show demo login credentials on the login page
# NEVER enable in production
VITE_DEMO_MODE=false

# ── Docker Compose ────────────────────────────────────────
CLIENT_PORT=3000
